# ============================================================
# Mắt Việt HR — Environment Variables
# Copy to .env.local for development; set in Netlify UI for prod
# ============================================================

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Mắt Việt HR"

# ---------- Supabase (project ref: xeyqbapegqeibeqrwnkm, region: ap-southeast-2) ----------
NEXT_PUBLIC_SUPABASE_URL=https://xeyqbapegqeibeqrwnkm.supabase.co
# Legacy JWT keys — used by @supabase/supabase-js@2.47 / @supabase/ssr until they ship native sb_* support
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
# New-format keys — recorded for Edge Function secrets + future migration
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ---------- Microsoft Graph (hr@matviet.com.vn) ----------
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX_ADDRESS=hr@matviet.com.vn
MS_TIMEZONE=SE Asia Standard Time

# ---------- Gemini 2.5 Flash (paid tier) ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------- LibreOffice DOCX→PDF Worker ----------
LIBREOFFICE_WORKER_URL=
LIBREOFFICE_WORKER_SECRET=

# ---------- Cron + scoring ----------
CRON_SECRET=
# Server Action → Edge Function bearer for /functions/v1/score-candidate
SCORING_INTERNAL_SECRET=

# ---------- Sentry ----------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=matviet-hr
